# Claude Code: KEEP `.claude/` rules / settings / agents / commands / hooks tracked so collaborators
# inherit the same workspace conventions. Only ignore ephemeral caches. Do NOT add `.claude/` itself
# here — that would drop `CLAUDE.md`'s companion config (settings.local.json, agents/, commands/,
# hooks/) and force every contributor to reconfigure. Same intent as `.cursor/rules/` staying tracked.
.claude/cache/

# ephemeral logs / local tooling output
logs/

# python tool caches (e.g. images/optimize-here)
__pycache__/
*.py[cod]
.classpath
.project

